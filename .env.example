# Copy to `.env` in the project root (`.env` is gitignored).
# Used by: `scripts/run_ios_social.sh`, VS Code launch, and `flutter run --dart-define-from-file=.env`

TMDB_API_KEY=YOUR_TMDB_V3_KEY
OMDB_API_KEY=YOUR_OMDB_KEY

TMDB_USE_SAMPLE_FALLBACK=false
SOCIAL_UI_ENABLED=true
FRIENDS_FEED_ENABLED=true
FIREBASE_PROJECT_ID=popmatch-48560
