rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // User profile document (not subcollections)
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
    }

    // Own follow requests inbox and privacy — flat paths avoid nested-match edge cases
    match /users/{uid}/incomingRequests/{requesterUid} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/privacy/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /followEdges/{edgeId} {
      allow read, write: if isSignedIn();
    }

    match /socialActivities/{activityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
